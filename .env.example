# Firebase client config — copy this file to .env.local and fill in your values
# Get these from Firebase Console → Project Settings → Your apps → Web app → SDK setup

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to true to point all Firebase calls to the local Emulator Suite (recommended for dev)
VITE_USE_EMULATORS=true
